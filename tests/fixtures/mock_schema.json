    {"name": "Cantidad Total", "expression": "SUM(Ventas[Cantidad])", "table": "Ventas"},
    {"name": "Ventas Anio Anterior", "expression": "CALCULATE([Total Ventas], SAMEPERIODLASTYEAR(Calendario[Fecha]))", "table": "Ventas"},
    {"name": "Ticket Promedio", "expression": "DIVIDE([Total Ventas], [Cantidad Total])", "table": "Ventas"}
