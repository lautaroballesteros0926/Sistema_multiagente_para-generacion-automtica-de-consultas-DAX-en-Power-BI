# Proveedor de LLM principal: Gemini.
# Consigue una key gratis en https://aistudio.google.com/apikey
# Sin esta variable (o si Gemini falla/se queda sin cuota), el sistema cae
# AUTOMÁTICAMENTE al modelo local vía Ollama — ver la sección "Usar solo
# el modelo local" del README. No hace falta ningún cambio de código.
GEMINI_API_KEY=

# Respaldo local (Ollama), opcional. Los valores por defecto en
# config/settings.py ya apuntan acá; descomenta solo si usás otro
# modelo, host o puerto.
# LOCAL_MODEL=llama3.1
# LOCAL_BASE_URL=http://localhost:11434/v1

# Power BI real vía Azure AD / XMLA, opcional. No se usan mientras
# USE_MOCK=True (el valor por defecto): el sistema funciona de punta a
# punta con un modelo semántico simulado (tests/fixtures/mock_schema.json).
# TENANT_ID=
# CLIENT_ID=
# CLIENT_SECRET=
# WORKSPACE_ID=
# DATASET_ID=
